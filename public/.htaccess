# Static Next.js export — Hostinger (Apache)
#
# Upload the ENTIRE contents of `out/` (including the `_next` folder).

DirectoryIndex index.html index.htm
Options -Indexes -MultiViews

ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"

  # Fresh HTML after deploys (avoid stale chunk references). Safe on all Apache builds.
  <FilesMatch "\.(?:html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Fingerprints live under /_next/static/ — filenames change each build.
  <FilesMatch "\.(?:js|css|mjs|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:webp|avif|png|jpe?g|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>
