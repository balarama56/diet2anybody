# Copy to ".env.local" for local dev (Next.js does NOT load .env.example at runtime).
# Required for real email: SMTP_HOST, SMTP_USER, SMTP_PASS
# Optional: MAIL_FROM (defaults to Diet2Anybody <SMTP_USER>), MAIL_TO (default ram.56.v@gmail.com)
#
# With `npm run dev` only: if SMTP is incomplete, the form still succeeds and data is logged in the
# terminal (no email). Production (`next start`) requires full SMTP.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

# MAIL_FROM=Diet2Anybody <your-email@gmail.com>
MAIL_TO=ram.56.v@gmail.com
